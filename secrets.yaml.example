# Copy this file to `secrets.yaml` in your ESPHome config directory and fill
# in the values. `secrets.yaml` must NOT be committed to git.
#
# ESPHome will automatically read `secrets.yaml` whenever it encounters
# `!secret <key>` in a YAML file.
 
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"
